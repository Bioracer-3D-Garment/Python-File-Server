# Copy to .env and fill in values. Never commit .env.

# Required for fal_api adapter (IDM-VTON / CatVTON via fal.ai)
FAL_KEY=your_key_here

# Required for fashn_api adapter
FASHN_API_KEY=your_key_here

# Paths to locally cloned VTON repos (required for idm_vton / ootdiffusion adapters)
IDMVTON_REPO_PATH=IDM-VTON
OOTD_REPO_PATH=OOTDiffusion

# Paths to pose preprocessing tools (required for scripts/preprocess_poses.py)
DWPOSE_PATH=DWPose
SCHP_PATH=SCHP

# Override config values via env (optional)
# PIPELINE__VTON__ADAPTER=fashn_api
# PIPELINE__PIPELINE__WORKERS=8
